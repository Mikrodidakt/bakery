{                                                                                                                   
    "version": "4",
    "name": "boss",
    "description": "A miMX8MM with the flavour of boss",
    "arch": "imx8mm",
    "bb": {
        "machine": "imx8mm-var-dart",
        "variant": "release",
        "distro": "fslc-wayland",
        "initenv": "sources/poky/oe-init-build-env",
        "bblayersconf": [
            "LCONF_VERSION = \"7\"",
            "BBPATH = \"${TOPDIR}\"",
            "BSPDIR := \"${@os.path.abspath(os.path.dirname(d.getVar('FILE', True)) + '/../../..')}\"",
            "BBFILES ?= \"\"",
            "BBLAYERS = \" \\",
            "   ${BSPDIR}/sources/poky/meta \\",
            "   ${BSPDIR}/sources/poky/meta-poky \\",
            "   ${BSPDIR}/sources/meta-openembedded/meta-oe \\",
            "   ${BSPDIR}/sources/meta-openembedded/meta-multimedia \\",
            "   ${BSPDIR}/sources/meta-openembedded/meta-python \\",
            "   ${BSPDIR}/sources/meta-openembedded/meta-filesystems \\",
            "   ${BSPDIR}/sources/meta-openembedded/meta-gnome \\",
            "   ${BSPDIR}/sources/meta-openembedded/meta-networking \\",
            "   ${BSPDIR}/sources/meta-freescale \\",
            "   ${BSPDIR}/sources/meta-freescale-3rdparty \\",
            "   ${BSPDIR}/sources/meta-freescale-distro \\",
            "   ${BSPDIR}/sources/meta-freescale-ml \\",
            "   ${BSPDIR}/sources/meta-clang \\",
            "   ${BSPDIR}/sources/meta-browser/meta-chromium \\",
            "   ${BSPDIR}/sources/meta-python2 \\",
            "   ${BSPDIR}/sources/meta-swupdate \\",
            "   ${BSPDIR}/sources/meta-virtualization \\",
            "   ${BSPDIR}/sources/meta-variscite-bsp \\",
            "   ${BSPDIR}/sources/meta-variscite-sdk \\",
            "   ${BSPDIR}/sources/meta-variscite-hab \\",
            "   ${BSPDIR}/sources/meta-mender/meta-mender-core \\",
            "   ${BSPDIR}/sources/meta-mender/meta-mender-demo \\",
            "   ${BSPDIR}/sources/meta-mender-community/meta-mender-variscite \\",
            "   ${BSPDIR}/sources/meta-flutter \\",
            "   ${BSPDIR}/sources/meta-flutter-plugins \\",
            "   ${BSPDIR}/sources/meta-iot-cloud \\",
            "   ${BSPDIR}/sources/meta-sct \\",
            "\""
        ],
        "localconf": [
            "MENDER_ARTIFACT_NAME ?= \"TestRelease-64\"",
            "PACKAGE_CLASSES ?= 'package_rpm'",
            "EXTRA_IMAGE_FEATURES ?= \"debug-tweaks\"",
            "USER_CLASSES ?= \"buildstats\"",
            "PATCHRESOLVE = \"noop\"",
            "BB_DISKMON_DIRS ??= \" \\",
            "   STOPTASKS,${TMPDIR},1G,100K \\ ",
            "   STOPTASKS,${DL_DIR},1G,100K \\ ",
            "   STOPTASKS,${SSTATE_DIR},1G,100K \\ ",
            "   STOPTASKS,/tmp,100M,100K \\ ",
            "   HALT,${TMPDIR},100M,1K \\ ",
            "   HALT,${DL_DIR},100M,1K \\ ",
            "   HALT,${SSTATE_DIR},100M,1K \\ ",
            "   HALT,/tmp,10M,1K \"",
            "PACKAGECONFIG:append:pn-qemu-system-native = \" sdl\"",
            "CONF_VERSION = \"2\"",
            "BB_GENERATE_MIRROR_TARBALLS = \"1\"",
            "BB_SIGNATURE_HANDLER = \"OEEquivHash\"",
            "BB_HASHSERVE = \"auto\"",
            "ACCEPT_FSL_EULA = \"1\"",
            "MENDER_IMAGE_BOOTLOADER_FILE = \"u-boot-spl.img\"",
            "MENDER_IMAGE_BOOTLOADER_BOOTSECTOR_OFFSET = \"2\"",
            "IMAGE_BOOT_FILES = \"\"",
            "MENDER_BOOT_PART_SIZE_MB = \"0\"",
            "DISTRO_FEATURES:append = \" wifi\"",
            "DISTRO_FEATURES:append = \" systemd\"",
            "VIRTUAL-RUNTIME_init_manager = \"systemd\"",
            "DISTRO_FEATURES_BACKFILL_CONSIDERED = \"sysvinit\"",
            "VIRTUAL-RUNTIME_initscripts = \"\"",
            "MENDER_PARTITION_ALIGNMENT = \"4194304\"",
            "IMAGE_FSTYPES:remove = \"tar.gz ext4 wic.gz wic.bmap multiubi mender.bmap\"",
            "MENDER_FEATURES_ENABLE:append = \" mender-uboot mender-image mender-client-install\"",
            "MENDER_FEATURES_DISABLE:append = \" mender-grub mender-image-uefi\"",
            "MENDER_FEATURES_ENABLE:append:imx8mm-var-dart = \" mender-image-sd \"",
            "MENDER_IMAGE_BOOTLOADER_FILE:imx8mm-var-dart = \"imx-boot\"",
            "MENDER_IMAGE_BOOTLOADER_BOOTSECTOR_OFFSET:imx8mm-var-dart = \"66\"",
            "MENDER_STORAGE_DEVICE_BASE:imx8mm-var-dart = \"/dev/mmcblk2p\"",
            "MENDER_STORAGE_DEVICE:imx8mm-var-dart = \"/dev/mmcblk2\"",
            "MENDER_UBOOT_STORAGE_DEVICE:imx8mm-var-dart = \"1\"",
            "UBOOT_CONFIG:imx8mm-var-dart = \"sd\"",
            "MENDER_STORAGE_TOTAL_SIZE_MB:imx8mm-var-dart = \"14500\"",
            "MENDER_DATA_PART_SIZE_MB = \"1024\"",
            "MENDER_SERVER_URL = \"https://eu.hosted.mender.io\"",
            "MENDER_TENANT_TOKEN = \"eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9.eyJtZW5kZXIudGVuYW50IjoiNjQ0OTEyMWJhY2E2OGY2NzJhZjZiZGMzIiwiaXNzIjoiTWVuZGVyIiwic3ViIjoiNjQ0OTEyMWJhY2E2OGY2NzJhZjZiZGMzIn0.pAuv679bG3slr5J5tBgYC6mJXBuISm9AaBUL3N53PBAsPbs_0pXu3KYLl9jn4ti2Tzymc9K2Xo21mB15fhAN1mkLsTAA-5HweC__vrVwq_xI_yF3NDis15sdwF5o8QbNSPyBvxbX6rDYlVkbldSaG9m1ESpPPHt6AoX4xq6YZmJuNM2mMJTjHyGKYkrgQmNyLXGndnMEinYnGpRiYapeojystY0_dJ9lkkzk8_CmvPVl7Q03K8E2kYWIVEq2AFKxXy7e6QnYs39WRJ28_rjI98mzlqg0SP-8IfLUeqSdj03MQkVVwAMAJty_Ws7V2v-1vDk2vhIRQoJla6WbDmB13OGJwv1PUtXq8HxkRXotPdvqZtJdRz_69logsitq7sRInvZ2oa44M5FOiZK0rPdC7OowUdOoGSrqzzmp3ioC9y-Ql1bDzKFOqvwqBYPNfx-k4CxMJ88_DO1g1-l658HxsVAvESsojIZr3FJD4Ak-ZfOhtw3ke684FdkUuiO9EkBK\"",
            "IMAGE_INSTALL:append = \" python3\"",
            "IMAGE_INSTALL:append = \" python3-requests\"",
            "IMAGE_INSTALL:append = \" python3-pip\"",
            "IMAGE_INSTALL:append = \" python3-bluezero\"",
            "IMAGE_INSTALL:append = \" python3-paho-mqtt\"",
            "IMAGE_INSTALL:append = \" git\"",
            "IMAGE_INSTALL:append = \" packagegroup-core-buildessential\"",
            "IMAGE_INSTALL:append = \" mosquitto\"",
            "IMAGE_INSTALL:append = \" gcc\"",
            "IMAGE_INSTALL:append = \" make\"",
            "IMAGE_INSTALL:append = \" autoconf\"",
            "IMAGE_INSTALL:append = \" libtool\"",
            "IMAGE_INSTALL:append = \" automake\"",
            "IMAGE_INSTALL:append = \" cmake\"",
            "IMAGE_INSTALL:append = \" sqlite3\"", 
            "IMAGE_INSTALL:append = \" dhcpcd\"",
            "IMAGE_INSTALL:append = \" brain\"",
            "IMAGE_INSTALL:append = \" brain-auto-launcher\"",
            "GLIBC_GENERATE_LOCALES:append = \" en_US.UTF-8 es_US.UTF-8 en_GB.UTF-8\"",
            "IMAGE_LINGUAS:append = \" en-us en-gb es-us\"",
            "CLANGSDK = \" 1\"",
            "LICENSE_FLAGS_ACCEPTED += \"commercial\"",
            "TOOLCHAIN_HOST_TASK:append = \" nativesdk-flutter-sdk\"",
            "IMAGE_INSTALL:append = \" kmscube libdrm-tests\"",
            "IMAGE_INSTALL:append = \" flutter-auto-runtimerelease\"",
            "IMAGE_INSTALL:append = \" flutter-gallery-runtimerelease\"",
            "IMAGE_INSTALL:append = \" flutter-test-texture-egl-runtimerelease\"",
            "IMAGE_INSTALL:append = \" flutter-test-video-player-runtimerelease\"",
            "IMAGE_INSTALL:append = \" flutter-test-localization-runtimerelease\"",
            "IMAGE_INSTALL:append = \" flutter-test-frb-runtimerelease\"",
            "IMAGE_INSTALL:append = \" flutter-pi-runtimerelease\"",
            "PACKAGECONFIG:append:pn-weston = \" remoting\"",
            "MACHINE_ESSENTIAL_EXTRA_RRECOMMENDS += \"kernel-modules\"",
            "PREFERRED_PROVIDER_libserialport = \"6f9b03e\"",
            "IMAGE_INSTALL:append = \" libserialport\"",
            "CORE_IMAGE_EXTRA_INSTALL += \"packagegroup-cloud-azure\""
        ]
    },
    "tasks": {
        "image": { 
            "index": "1",
            "name": "image",
            "recipes": [
                "fsl-image-gui"
            ]
        }
    }
}
